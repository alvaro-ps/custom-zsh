{
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "theme": "catppuccin-macchiato",
  "autoupdate": true,
  "mcp": {
    "jira": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "github": {
      "type": "remote",
      "enabled": true,
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_API_KEY}"
      }
    }
  }
}
